{
  "name": "local-react-preview-mvp",
  "version": "0.1.0",
  "description": "本地前端项目预览与公网分享桌面工具",
  "author": "OpenAI Codex + ZhuanZ",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server/server.ts",
    "desktop": "electron .",
    "dev:client": "vite --host 0.0.0.0",
    "build": "vite build",
    "dist:win": "cross-env ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-builder --win nsis",
    "dist:win:portable": "cross-env ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-builder --win portable",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "main": "electron/main.ts",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vitejs/plugin-react": "^5.0.0",
    "adm-zip": "^0.5.16",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "localtunnel": "^2.0.2",
    "multer": "^1.4.5-lts.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sirv": "^3.0.0",
    "tsx": "^4.19.2",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@types/supertest": "^6.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "jsdom": "^25.0.1",
    "supertest": "^7.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "com.codex.local-live-share",
    "productName": "Local Live Share",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "dist/client/**/*",
      "bin/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
